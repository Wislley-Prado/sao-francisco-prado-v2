# React/Vite SPA fallback for Apache (Hostinger)
# Sends all non-file/non-folder requests to index.html so React Router can handle routes

RewriteEngine On
RewriteBase /

# --- BOT PROXY START ---
RewriteCond %{REQUEST_URI} ^/blog/ [NC]
RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|whatsapp|twitterbot|pinterest|linkedinbot|vkShare|W3C_Validator|baiduspider|googlebot|bingbot|yandexbot|slackbot|discordbot|telegrambot) [NC]
RewriteCond %{QUERY_STRING} !no_bot=1 [NC]
RewriteRule ^ bot.php [L]
# --- BOT PROXY END ---

# 1. Se o arquivo ou diretório existe fisicamente, serve diretamente
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 2. Se a requisição for para um asset estático (.js, .css, etc.) que NAO existe mais no servidor, retorna 404 em vez de index.html
RewriteCond %{REQUEST_URI} \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|json|map)$ [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ - [R=404,L]

# 3. Para qualquer outra rota virtual de página SPA, reescreve para index.html
RewriteRule ^ index.html [L]

# --- BROTLI & GZIP COMPRESSION FOR HOSTINGER / APACHE ---
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json application/xml image/svg+xml image/x-icon font/ttf font/otf font/woff font/woff2
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json application/xml image/svg+xml image/x-icon font/ttf font/otf font/woff font/woff2
</IfModule>

# --- BROWSER CACHING FOR HOSTINGER & SPA ANTI-WHITE-SCREEN ---
<IfModule mod_headers.c>
  # Manter conexao HTTP ativa para diminuir latencia do documento
  Header set Connection keep-alive

  # NUNCA fazer cache de documentos HTML (index.html, *.html, sw.js, manifest.json, bot.php)
  <FilesMatch "\.(html|htm|php)$|^(index\.html|sw\.js|registerSW\.js|manifest\.json|bot\.php)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
  
  # Assets compilados em JS/CSS, imagens e fontes possuem hash no nome e sao cacheados por 1 ano com seguranca
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|webp|avif|woff|woff2|ttf|eot|json)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/json "access plus 0 seconds"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

