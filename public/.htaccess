# React/Vite SPA fallback for Apache (Hostinger)
# Sends all non-file/non-folder requests to index.html so React Router can handle routes

RewriteEngine On
RewriteBase /

# --- BOT PROXY START ---
# Se a requisição for para o /blog/ e vier de um bot conhecido (WhatsApp, Facebook, etc), envia para o bot.php
RewriteCond %{REQUEST_URI} ^/blog/ [NC]
RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|whatsapp|twitterbot|pinterest|linkedinbot|vkShare|W3C_Validator|baiduspider|googlebot|bingbot|yandexbot|slackbot|discordbot|telegrambot) [NC]
RewriteCond %{QUERY_STRING} !no_bot=1 [NC]
RewriteRule ^ bot.php [L]
# --- BOT PROXY END ---

# If the request is for an existing file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise, rewrite everything to index.html
RewriteRule ^ index.html [L]

# --- GZIP COMPRESSION FOR HOSTINGER ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json application/xml image/svg+xml
</IfModule>

# --- BROWSER CACHING FOR HOSTINGER & SPA ANTI-WHITE-SCREEN ---

# 1. NUNCA fazer cache do index.html, sw.js e manifest.json para evitar telas brancas pós-deploy
<IfModule mod_headers.c>
  <FilesMatch "^(index\.html|sw\.js|registerSW\.js|manifest\.json|bot\.php)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
  
  # Assets compilados em /assets/ possuem hash no nome e podem ser cacheados com seguranca
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  # HTML e JSON devem expirar imediatamente
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/json "access plus 0 seconds"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

